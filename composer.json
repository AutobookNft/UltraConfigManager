{
    "name": "ultra/ultra-config-manager",
    "description": "A configuration management library designed for Laravel to streamline handling configuration values with validation support.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fabio Cherici", 
            "email": "fabiocherici@gmail.com" 
        }
    ],
     "require": {
        "php": "^8.1|^8.2|^8.3",
        "laravel/framework": "^11.0",
        "monolog/monolog": "^3.0" 
    },
    "autoload": {
        "psr-4": {
            "Ultra\\UltraConfigManager\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ultra\\UltraConfigManager\\Providers\\UltraConfigManagerServiceProvider", 
                "Ultra\\UltraConfigManager\\Providers\\ValidationServiceProvider" 
            ]
        
        }
    },
    "minimum-stability": "stable"
    
}